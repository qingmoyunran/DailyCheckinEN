# ===== Ignore everything by default =====
*

# ===== Allow source code =====
!src/
!src/**/
!src/**/*.ts
!src/**/*.tsx
!src/**/*.css
!src/**/*.html

# ===== Allow deployment-necessary config files =====
!.gitignore
!package.json
!package-lock.json
!tsconfig.json
!vite.config.ts
!tailwind.config.js
!postcss.config.js
!eslint.config.js
!index.html
!README.md

# ===== Allow minimal public assets =====
!public/
!public/favicon.svg

# ===== But still ignore these even inside allowed dirs =====
node_modules/
dist/
dist-ssr/
*.log
*.local
.env
.env.*
